  "usecase_voting": {
    "_comment": "Use case: voting / ballot — each participant gets a unique scannable card.",
    "jsonrpc": "2.0",
    "id": 7,
    "method": "tools/call",
    "params": {
      "name": "generate-lineup",
      "arguments": {
