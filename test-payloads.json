{
  "_comment": "Test payloads for the Lineup MCP server. Use with: curl -s -X POST http://localhost:3000/mcp -H 'Content-Type: application/json' -H 'Accept: application/json, text/event-stream' -d @<payload>",

  "tools_list": {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/list"
  },

  "berlin_hack_night": {
    "jsonrpc": "2.0",
    "id": 2,
    "method": "tools/call",
    "params": {
      "name": "generate-lineup",
      "arguments": {
        "title": "Berlin Hack Night",
        "dateISO": "2026-05-28T18:00:00+02:00",
