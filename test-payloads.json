  "usecase_announcement": {
    "_comment": "Use case: fast announcement — spin up an event in one sentence (the Luma-killer demo).",
    "jsonrpc": "2.0",
    "id": 9,
    "method": "tools/call",
    "params": {
      "name": "generate-lineup",
      "arguments": {
